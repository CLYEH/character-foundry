# ── Required secrets（prod 請換成 `openssl rand -hex 32` 產的值）──────
POSTGRES_PASSWORD=change_me
REDIS_PASSWORD=change_me
JWT_SECRET=change_me_32_bytes_hex
STORAGE_SIGNED_URL_SECRET=change_me_32_bytes_hex

# ── Authentik OAuth provider (T-052)──────────────────────────────────
# AUTHENTIK_SECRET_KEY 用 `openssl rand -base64 32` 產
# AUTHENTIK_POSTGRES_PASSWORD 跟主 app POSTGRES_PASSWORD 分開（獨立 DB instance）
AUTHENTIK_SECRET_KEY=change_me_base64_32
AUTHENTIK_POSTGRES_PASSWORD=change_me

# ── External AI APIs（dev 可留空，Sprint 0 不會呼叫）──────────────────
OPENAI_API_KEY=            # gpt-image-2 + gpt-5-mini reconciler 共用
VEO_API_KEY=               # Google Veo 3.1
VEO_API_URL=https://generativelanguage.googleapis.com/v1beta

# ── Postgres ────────────────────────────────────────────────────────
POSTGRES_DB=character_foundry
POSTGRES_USER=cf_app

# ── Infra URLs（docker compose 內部 hostname）────────────────────────
DATABASE_URL=postgresql+asyncpg://cf_app:change_me@postgres:5432/character_foundry
REDIS_URL=redis://:change_me@redis:6379/0

# ── Test DB（跑 migration 測試前再設；留空會 skip 測試）───────────────
# ⚠ 這個 URL 指到的 DB 會被 pytest DROP 掉所有 table。不要用 prod/開發主 DB。
# 建議：先 `CREATE DATABASE character_foundry_test;` 再填入下方。
TEST_DATABASE_URL=

# ── Storage ─────────────────────────────────────────────────────────
STORAGE_ROOT=/storage

# ── Tunable（可留預設）───────────────────────────────────────────────
WORKER_CONCURRENCY=4
LOG_LEVEL=INFO
SOFT_DELETE_RETENTION_DAYS=30
TASK_TERMINAL_RETENTION_HOURS=24

# ── Frontend（VITE_ 前綴會 inline 進 bundle，禁放 secret）─────────────
VITE_API_BASE_URL=/api
VITE_STORAGE_BASE_URL=/storage
VITE_APP_VERSION=0.1.0
