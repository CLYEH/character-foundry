# ── Required secrets（prod 請換成 `openssl rand -hex 32` 產的值）──────
POSTGRES_PASSWORD=change_me
REDIS_PASSWORD=change_me
JWT_SECRET=change_me_32_bytes_hex
STORAGE_SIGNED_URL_SECRET=change_me_32_bytes_hex

# ── External AI APIs（dev 可留空，Sprint 0 不會呼叫）──────────────────
OPENAI_API_KEY=
SEEDANCE_API_KEY=
ANTHROPIC_API_KEY=

# ── Postgres ────────────────────────────────────────────────────────
POSTGRES_DB=character_foundry
POSTGRES_USER=cf_app

# ── Infra URLs（docker compose 內部 hostname）────────────────────────
DATABASE_URL=postgresql+asyncpg://cf_app:change_me@postgres:5432/character_foundry
REDIS_URL=redis://:change_me@redis:6379/0

# ── Storage ─────────────────────────────────────────────────────────
STORAGE_ROOT=/storage

# ── Tunable（可留預設）───────────────────────────────────────────────
WORKER_CONCURRENCY=4
LOG_LEVEL=INFO
SOFT_DELETE_RETENTION_DAYS=30
TASK_TERMINAL_RETENTION_HOURS=24

# ── Frontend（VITE_ 前綴會 inline 進 bundle，禁放 secret）─────────────
VITE_API_BASE_URL=/api
VITE_STORAGE_BASE_URL=/storage
VITE_APP_VERSION=0.1.0
