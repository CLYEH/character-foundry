# ── Required secrets（prod 請換成 `openssl rand -hex 32` 產的值）──────
# docker-compose.yml interpolates the password/key secrets as
# `${VAR:?must be set}` (T-067). An unset OR empty value aborts
# `docker compose config` / `up` with a named error instead of silently
# injecting an empty secret (e.g. a passwordless Postgres) — so each secret
# below must carry a real value before the stack will start. (JWT_SECRET +
# STORAGE_SIGNED_URL_SECRET reach api/worker via `env_file`, not compose
# interpolation, so they are not guarded at the compose layer — but the app
# still requires them.)
POSTGRES_PASSWORD=change_me
REDIS_PASSWORD=change_me
JWT_SECRET=change_me_32_bytes_hex
STORAGE_SIGNED_URL_SECRET=change_me_32_bytes_hex

# ── Authentik OAuth provider (T-052)──────────────────────────────────
# AUTHENTIK_SECRET_KEY 用 `openssl rand -base64 32` 產
# AUTHENTIK_POSTGRES_PASSWORD 跟主 app POSTGRES_PASSWORD 分開（獨立 DB instance）
AUTHENTIK_SECRET_KEY=change_me_base64_32
AUTHENTIK_POSTGRES_PASSWORD=change_me

# ── Google upstream IdP for Authentik (T-053)─────────────────────────
# 從公司 Workspace admin → Google Cloud Console → APIs & Services →
# Credentials → "OAuth 2.0 Client IDs" 建一個 web application，redirect URI
# 設 https://<authentik-host>/oauth/source/oauth/callback/google/
# （dev = http://localhost/oauth/source/oauth/callback/google/）。
# 注意 `/oauth/` 前綴 — nginx 把 Authentik 反代在 /oauth/ 底下
# （infra/nginx/nginx.conf 的 `location /oauth/`），所以瀏覽器 / Google
# Cloud Console 看到的外部 callback URL 必含 /oauth/ 前綴；漏掉會 redirect_uri_mismatch.
# Authentik admin UI → Directory → Federation & Social login → Create
# OAuth Source 時填入下面兩個值。setup 細節見 planning/devops/authentik-stack.md §5.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=change_me

# ⚠ DO NOT add CF_TEST_AGENT_CLIENT_SECRET here — 1Password only.
# cf-test-agent (T-053 §5.4) is the M2M CI smoke client; its secret has full
# 5-scope blast radius. Keeping it out of `.env.example` prevents the pattern
# above from priming a future operator to commit it pre-filled. See
# planning/devops/authentik-stack.md §5.4 + §5.8.

# ── Backend dual-stack OAuth verification (T-054) ────────────────────
# Backend (`app.auth.oauth`) verifies Authentik-issued access tokens locally
# using RS256 public keys fetched from `AUTHENTIK_JWKS_URL`. Tokens whose
# `iss` claim matches `AUTHENTIK_ISSUER_URL` go through the OAuth path;
# everything else falls through to the legacy HS256 JWT path
# (`app.auth.jwt`). The `iss` strings MUST differ between the two paths
# (Authentik token's `iss` is the full provider URL; internal JWTs do not
# carry `iss`). Leave the OAuth vars unset during the pre-Sprint 3.5a
# dev period — the OAuth path is then never selected.
# AUTHENTIK_ISSUER_URL and AUTHENTIK_AUDIENCE both accept comma-separated
# lists — Authentik issues per-application providers (character-foundry-spa,
# 3 delegated brands, 1 M2M cf-test-agent, plus the dedicated MCP OAuth app
# `character-foundry-mcp` from T-089), so each app has its own `iss` URL and
# `aud` client_id. List EVERY sanctioned app's issuer here so its tokens
# verify; a single value still works for single-app deployments. In
# particular, delegated MCP clients that auto-login via discovery (T-089)
# present `character-foundry-mcp` tokens — include its issuer/aud or `/mcp/`
# rejects them with AUTH_CLIENT_NOT_ALLOWED.
# AUTHENTIK_ISSUER_URL entries are per-provider:
# `https://<host>/oauth/application/o/<application-slug>/` (Authentik
# admin UI → Applications → <App> → "OpenID Configuration Issuer").
# AUTHENTIK_AUDIENCE entries are the corresponding `client_id` values.
AUTHENTIK_ISSUER_URL=
AUTHENTIK_AUDIENCE=
# Optional override; default is `<first-AUTHENTIK_ISSUER_URL>/jwks/`. Set
# this when the nginx topology rewrites the JWKS path. Single value only —
# all Authentik apps share one JWKS endpoint per Authentik instance.
AUTHENTIK_JWKS_URL=

# ── Backend OAuth auto-provisioning (T-071) ──────────────────────────
# Comma-separated email-domain allowlist. When an Authentik-verified
# delegated token has no matching `users` row, `_resolve_oauth` will
# auto-provision the row only if the token email's domain is in this
# allowlist. Unset / empty → fail-closed (every first-login stays 401;
# operators must use `provision-operator` CLI to pre-create rows). Set
# this to your Workspace tenant domain (same value used for Authentik's
# Google OAuth Source `hd=` gate — defense in depth, see
# `planning/devops/authentik-stack.md` §5.7.2.a).
OAUTH_AUTO_PROVISION_ALLOWED_DOMAINS=

# ── MCP transport security (T-080 / T-090) ───────────────────────────
# DNS-rebinding protection for the streamable-HTTP MCP server mounted at
# `/mcp` (reverse-proxied by nginx `location /mcp/`, T-082). Comma-separated
# allowlists; both default to loopback (bare + `:port` forms) so local dev
# works out of the box. The `Host` header nginx forwards is the browser/
# client's real host (`$host`), so PROD MUST add the public host here or the
# server returns `421 Invalid Host header`.
#   • Include BOTH bare and `:port` forms when a client may hit a default
#     port — a standard client sends `Host: foo.example` (no port) to :443,
#     which only the bare entry matches; `foo.example:*` alone would 421.
#   • ngrok example: inheritable-fleshly-jameson.ngrok-free.dev,inheritable-fleshly-jameson.ngrok-free.dev:*
#   • custom domain example: foundry.example.com,foundry.example.com:*
# MCP_ALLOWED_ORIGINS gates the browser `Origin` header (same comma form,
# scheme-qualified, e.g. https://foundry.example.com); set it for any web-
# based MCP client.
# ⚠ Leave BOTH lines COMMENTED OUT in dev to get the loopback defaults. An
# explicit empty value is NOT the same as unset: `env_file: .env` injects
# `MCP_ALLOWED_HOSTS=` into the container as an empty string, which the server
# reads as "allow zero hosts" → `421 Invalid Host header` on EVERY request
# (localhost included). Uncomment + fill in only when you have a real host.
#MCP_ALLOWED_HOSTS=foundry.example.com,foundry.example.com:*
#MCP_ALLOWED_ORIGINS=https://foundry.example.com

# ── MCP OAuth discovery (T-089) ──────────────────────────────────────
# The MCP server publishes RFC 9728 Protected Resource Metadata at
# `/.well-known/oauth-protected-resource` and answers a no-token `/mcp/`
# request with `401 + WWW-Authenticate` so OAuth-capable MCP clients
# auto-login (no manual Bearer paste). The advertised `resource` /
# `authorization_servers` / metadata URLs need the server's PUBLIC base URL.
# By default the server DERIVES it from the request (`X-Forwarded-Proto` +
# `Host`, both forwarded by nginx), which auto-adapts to localhost / ngrok /
# prod. Set MCP_PUBLIC_BASE_URL to PIN it instead (recommended in prod —
# robust against Host-header spoofing). No trailing slash.
#   • dev (derive): leave unset.
#   • prod example: https://foundry.example.com
# The delegated MCP clients all use client_id `character-foundry-mcp`; its
# Authentik issuer/aud must be in AUTHENTIK_ISSUER_URL / AUTHENTIK_AUDIENCE
# above. Per-client redirect_uri conventions: see
# planning/devops/authentik-stack.md §5.4.
#MCP_PUBLIC_BASE_URL=https://foundry.example.com

# ── External AI APIs（dev 可留空，Sprint 0 不會呼叫）──────────────────
OPENAI_API_KEY=            # gpt-image-2 + gpt-5-mini reconciler 共用
VEO_API_KEY=               # Google Veo 3.1
VEO_API_URL=https://generativelanguage.googleapis.com/v1beta

# ── Postgres ────────────────────────────────────────────────────────
POSTGRES_DB=character_foundry
POSTGRES_USER=cf_app

# ── Infra URLs（docker compose 內部 hostname）────────────────────────
DATABASE_URL=postgresql+asyncpg://cf_app:change_me@postgres:5432/character_foundry
REDIS_URL=redis://:change_me@redis:6379/0

# ── Test DB（跑 migration 測試前再設；留空會 skip 測試）───────────────
# ⚠ 這個 URL 指到的 DB 會被 pytest DROP 掉所有 table。不要用 prod/開發主 DB。
# 建議：先 `CREATE DATABASE character_foundry_test;` 再填入下方。
TEST_DATABASE_URL=

# ── Storage ─────────────────────────────────────────────────────────
STORAGE_ROOT=/storage

# ── Tunable（可留預設）───────────────────────────────────────────────
WORKER_CONCURRENCY=4
LOG_LEVEL=INFO
SOFT_DELETE_RETENTION_DAYS=30
TASK_TERMINAL_RETENTION_HOURS=24

# ── Frontend（VITE_ 前綴會 inline 進 bundle，禁放 secret）─────────────
VITE_API_BASE_URL=/api
VITE_STORAGE_BASE_URL=/storage
VITE_APP_VERSION=0.1.0

# ── Frontend OAuth (T-056) ───────────────────────────────────────────
# Public Authentik endpoints exposed via nginx (`/oauth/` prefix). SPA needs
# the authorize URL to start PKCE, the token URL to exchange the code, and
# the revoke URL (RFC 7009) to invalidate the refresh token on sign-out.
# `LOGOUT_URL` is NOT Authentik's OIDC end-session endpoint — that one wants
# `id_token_hint` + a redirect dance for global session termination, which
# Phase 1 single-user does not need. We only revoke the refresh token.
# `CLIENT_ID` is the public `character-foundry-spa` client registered in
# T-053 §5.4 — no secret (public PKCE client).
#
# AUTHORIZE_URL is ABSOLUTE (to Authentik's real origin), TOKEN/LOGOUT stay
# relative — deliberate, see T-076. AUTHORIZE_URL is *navigated to*: it (and
# the cf-google-init flow URL derived from it) load Authentik flow-interface
# pages whose bootstrap XHRs hit Authentik's absolute `base_url`. If the SPA
# navigated there via the same-origin `/oauth/` vite proxy (`:5173`), those
# XHRs would be cross-origin (`:5173` → `:80`) and CORS-blocked → the flow
# interface stalls at "Loading…". Navigating to `:80` directly keeps the
# flow interface + its API same-origin. TOKEN/LOGOUT are *fetched* from the
# SPA on `:5173`, so relative + the vite `/oauth/` proxy is correct for them.
# `redirect_uri` stays the SPA's own origin (`window.location.origin`), so
# the user still lands back on `:5173` after login. Prod: set AUTHORIZE_URL
# to the full prod Authentik absolute URL (including the
# `/application/o/authorize/` path); same-origin deploys may use a relative
# path instead. (CI keeps a relative value — it is single-origin; see
# .github/workflows/pr.yml.)
VITE_AUTHENTIK_AUTHORIZE_URL=http://localhost/oauth/application/o/authorize/
VITE_AUTHENTIK_TOKEN_URL=/oauth/application/o/token/
VITE_AUTHENTIK_LOGOUT_URL=/oauth/application/o/revoke/
VITE_AUTHENTIK_CLIENT_ID=character-foundry-spa
# Visibility gate for the Google direct-shortcut button on /login (T-068).
# Non-empty → the button shows; blank → it's hidden and /login falls back
# to the identification page only.
#
# Since T-073 this is ONLY an on/off gate — the value is no longer routed
# anywhere. The SPA sends the user through the `cf-google-init` Authentik
# flow (infra/authentik/blueprints/cf-google-init.yaml), whose RedirectStage
# statically targets the `google` source-init URL. The upstream OAuth
# Source slug is locked to `google` (planning/devops/authentik-stack.md
# §5.2 — it must match the Google Cloud Console redirect URI verbatim), so
# setting this to anything other than `google`/blank has no routing effect.
VITE_AUTHENTIK_GOOGLE_SOURCE_SLUG=google
