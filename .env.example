# ── Required secrets（prod 請換成 `openssl rand -hex 32` 產的值）──────
POSTGRES_PASSWORD=change_me
REDIS_PASSWORD=change_me
JWT_SECRET=change_me_32_bytes_hex
STORAGE_SIGNED_URL_SECRET=change_me_32_bytes_hex

# ── Authentik OAuth provider (T-052)──────────────────────────────────
# AUTHENTIK_SECRET_KEY 用 `openssl rand -base64 32` 產
# AUTHENTIK_POSTGRES_PASSWORD 跟主 app POSTGRES_PASSWORD 分開（獨立 DB instance）
AUTHENTIK_SECRET_KEY=change_me_base64_32
AUTHENTIK_POSTGRES_PASSWORD=change_me

# ── Google upstream IdP for Authentik (T-053)─────────────────────────
# 從公司 Workspace admin → Google Cloud Console → APIs & Services →
# Credentials → "OAuth 2.0 Client IDs" 建一個 web application，redirect URI
# 設 https://<authentik-host>/oauth/source/oauth/callback/google/
# （dev = http://localhost/oauth/source/oauth/callback/google/）。
# 注意 `/oauth/` 前綴 — nginx 把 Authentik 反代在 /oauth/ 底下
# （infra/nginx/nginx.conf 的 `location /oauth/`），所以瀏覽器 / Google
# Cloud Console 看到的外部 callback URL 必含 /oauth/ 前綴；漏掉會 redirect_uri_mismatch.
# Authentik admin UI → Directory → Federation & Social login → Create
# OAuth Source 時填入下面兩個值。setup 細節見 planning/devops/authentik-stack.md §5.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=change_me

# ⚠ DO NOT add CF_TEST_AGENT_CLIENT_SECRET here — 1Password only.
# cf-test-agent (T-053 §5.4) is the M2M CI smoke client; its secret has full
# 5-scope blast radius. Keeping it out of `.env.example` prevents the pattern
# above from priming a future operator to commit it pre-filled. See
# planning/devops/authentik-stack.md §5.4 + §5.8.

# ── Backend dual-stack OAuth verification (T-054) ────────────────────
# Backend (`app.auth.oauth`) verifies Authentik-issued access tokens locally
# using RS256 public keys fetched from `AUTHENTIK_JWKS_URL`. Tokens whose
# `iss` claim matches `AUTHENTIK_ISSUER_URL` go through the OAuth path;
# everything else falls through to the legacy HS256 JWT path
# (`app.auth.jwt`). The `iss` strings MUST differ between the two paths
# (Authentik token's `iss` is the full provider URL; internal JWTs do not
# carry `iss`). Leave the OAuth vars unset during the pre-Sprint 3.5a
# dev period — the OAuth path is then never selected.
# AUTHENTIK_ISSUER_URL and AUTHENTIK_AUDIENCE both accept comma-separated
# lists — Authentik issues per-application providers (T-053 §5.4 registers
# five: character-foundry-spa + 3 delegated + 1 M2M), so each app has its
# own `iss` URL and `aud` client_id. List all five so any sanctioned app's
# tokens verify; single value still works for single-app deployments.
# AUTHENTIK_ISSUER_URL entries are per-provider:
# `https://<host>/oauth/application/o/<application-slug>/` (Authentik
# admin UI → Applications → <App> → "OpenID Configuration Issuer").
# AUTHENTIK_AUDIENCE entries are the corresponding `client_id` values.
AUTHENTIK_ISSUER_URL=
AUTHENTIK_AUDIENCE=
# Optional override; default is `<first-AUTHENTIK_ISSUER_URL>/jwks/`. Set
# this when the nginx topology rewrites the JWKS path. Single value only —
# all Authentik apps share one JWKS endpoint per Authentik instance.
AUTHENTIK_JWKS_URL=

# ── External AI APIs（dev 可留空，Sprint 0 不會呼叫）──────────────────
OPENAI_API_KEY=            # gpt-image-2 + gpt-5-mini reconciler 共用
VEO_API_KEY=               # Google Veo 3.1
VEO_API_URL=https://generativelanguage.googleapis.com/v1beta

# ── Postgres ────────────────────────────────────────────────────────
POSTGRES_DB=character_foundry
POSTGRES_USER=cf_app

# ── Infra URLs（docker compose 內部 hostname）────────────────────────
DATABASE_URL=postgresql+asyncpg://cf_app:change_me@postgres:5432/character_foundry
REDIS_URL=redis://:change_me@redis:6379/0

# ── Test DB（跑 migration 測試前再設；留空會 skip 測試）───────────────
# ⚠ 這個 URL 指到的 DB 會被 pytest DROP 掉所有 table。不要用 prod/開發主 DB。
# 建議：先 `CREATE DATABASE character_foundry_test;` 再填入下方。
TEST_DATABASE_URL=

# ── Storage ─────────────────────────────────────────────────────────
STORAGE_ROOT=/storage

# ── Tunable（可留預設）───────────────────────────────────────────────
WORKER_CONCURRENCY=4
LOG_LEVEL=INFO
SOFT_DELETE_RETENTION_DAYS=30
TASK_TERMINAL_RETENTION_HOURS=24

# ── Frontend（VITE_ 前綴會 inline 進 bundle，禁放 secret）─────────────
VITE_API_BASE_URL=/api
VITE_STORAGE_BASE_URL=/storage
VITE_APP_VERSION=0.1.0
