#!/usr/bin/env bash
# Pre-push review gate (terminal side)
#
# Mirror of the Claude-side gate at .claude/hooks/pre-push-review.sh.
# Triggered by git directly so terminal-driven `git push` is also covered
# (the Claude-side hook only fires when Claude invokes Bash). Default
# behavior: reject the push with a clear directive to run the
# engineering-code-reviewer subagent first. Bypass with CF_SKIP_REVIEW=1
# (hotfix, docs-only, or re-pushing after review has been done).
#
# T-062: if the current branch's ticket file matches security-sensitive or
# schema-migration keywords, additionally direct Claude to chain
# `security-engineer` / `db-optimizer` on the same diff.
#
# Activated via `git config core.hooksPath .githooks` (run once per
# clone — see CONTRIBUTING.md).
#
# git pre-push contract: receives `<local ref> <local sha> <remote ref>
# <remote sha>` lines on stdin, exits non-zero to abort the push.

set -u

# T-063: bypass audit log. SOLE WRITER — appends one JSONL line to
# `.harness/skip-review.log` every time CF_SKIP_REVIEW=1 is honored. The
# Claude PreToolUse hook intentionally does NOT write (would double-count
# Claude-driven pushes since `git push` from Bash still fires THIS hook).
# File is gitignored; local accumulation only. See `.harness/README.md`.
append_skip_log() {
  local repo_root ts branch upstream range reason esc_branch esc_range esc_reason log
  repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || return 0
  log="$repo_root/.harness/skip-review.log"
  [ -d "$repo_root/.harness" ] || return 0
  ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  branch=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")
  upstream=$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || echo "")
  if [ -n "$upstream" ]; then
    range="${upstream}..HEAD"
  else
    range="origin/main..HEAD"
  fi
  reason="${CF_SKIP_REVIEW_REASON:-}"
  esc_branch="${branch//\\/\\\\}"; esc_branch="${esc_branch//\"/\\\"}"
  esc_range="${range//\\/\\\\}"; esc_range="${esc_range//\"/\\\"}"
  esc_reason="${reason//\\/\\\\}"; esc_reason="${esc_reason//\"/\\\"}"
  # Flatten all control chars to space — JSON requires C0 controls
  # (U+0000..U+001F) escaped (RFC 8259 §7), and a stray CRLF / `\r` from a
  # Windows clipboard would otherwise yield a line that fails `jq` / json.loads.
  # `[[:cntrl:]]` is the portable POSIX class (covers C0 + DEL); we avoid the
  # explicit `[$'\x00'-$'\x1f']` form because bash silently mis-matches when
  # NUL is in the range (verified locally on bash 5.2.37 msys).
  esc_reason="${esc_reason//[[:cntrl:]]/ }"
  printf '{"ts":"%s","branch":"%s","range":"%s","reason":"%s"}\n' \
    "$ts" "$esc_branch" "$esc_range" "$esc_reason" >> "$log" 2>/dev/null || true
}

if [ "${CF_SKIP_REVIEW:-0}" = "1" ]; then
  append_skip_log
  exit 0
fi

remote="${1:-?}"

# ── Ticket detection (same regex as .claude/hooks/pre-push-review.sh) ──
BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || true)
TICKET=$(printf '%s' "${BRANCH:-}" | grep -oiE 'T-[0-9]+' | head -1 || true)
TICKET=$(printf '%s' "${TICKET:-}" | tr '[:lower:]' '[:upper:]')

SEC_CHAIN=0
DB_CHAIN=0

if [ -n "${TICKET:-}" ]; then
  # Anchor to repo root so subdir / worktree invocations still resolve.
  REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || echo .)
  for f in "$REPO_ROOT"/tickets/${TICKET}-*.md "$REPO_ROOT"/tickets/DONE/${TICKET}-*.md; do
    [ -f "$f" ] || continue
    # `-i` makes the OAuth-template-header strip robust to casing drift in
    # tickets/_TEMPLATE.md (see CONTRIBUTING §4.4).
    body=$(grep -vi '^## OAuth scope' "$f")
    if printf '%s\n' "$body" | grep -qiE 'security-sensitive|oauth|\bjwt\b|\bpkce\b|bearer token|authentik|client_secret|refresh[._ ]token|scope decorator|secret scan|sast' ; then
      SEC_CHAIN=1
    fi
    if printf '%s\n' "$body" | grep -qiE 'alembic|alter table|add column|drop column|schema migration|migration script|\bbackfill\b|new index|enum column' ; then
      DB_CHAIN=1
    fi
  done
fi

print_header() {
  echo ""
  echo "════════════════════════════════════════════════════════════"
  echo "  PRE-PUSH REVIEW GATE  ($remote)"
  echo "════════════════════════════════════════════════════════════"
}

printed_any=0
zero_sha="0000000000000000000000000000000000000000"

while IFS=' ' read -r local_ref local_sha remote_ref remote_sha; do
  # Branch deletion (local sha is all zeros) — nothing to review.
  if [ "$local_sha" = "$zero_sha" ]; then
    continue
  fi

  # New branch on the remote — diff against origin/main (or first
  # commit of the branch if even main isn't there).
  if [ "$remote_sha" = "$zero_sha" ]; then
    if base=$(git rev-parse --verify --quiet origin/main); then
      :
    else
      base=$(git rev-list --max-parents=0 "$local_sha" | tail -n 1)
    fi
    range="${base}..${local_sha}"
  else
    range="${remote_sha}..${local_sha}"
  fi

  if [ "$printed_any" = "0" ]; then
    print_header
    printed_any=1
  fi

  echo ""
  echo "  Ref:    $local_ref → $remote_ref"
  echo "  Range:  $range"
  echo ""
  echo "  Commits to be pushed:"
  git log --oneline "$range" | sed 's/^/    /'
  echo ""
  echo "  Diff stat:"
  git diff --stat "$range" | sed 's/^/    /'
done

if [ "$printed_any" = "0" ]; then
  # Nothing substantive to review (e.g. all branch deletions). Allow.
  exit 0
fi

cat <<'EOF'

  ────────────────────────────────────────────────────────────
  Review the diff with the `engineering-code-reviewer`
  subagent in Claude Code before pushing.

EOF

if [ "$SEC_CHAIN" = "1" ]; then
  printf '  ADDITIONAL: ticket %s is security-sensitive — also run\n' "$TICKET"
  printf '  subagent_type=security-engineer on the same diff.\n\n'
fi

if [ "$DB_CHAIN" = "1" ]; then
  printf '  ADDITIONAL: ticket %s touches schema / migrations — also\n' "$TICKET"
  printf '  run subagent_type=db-optimizer on the same diff.\n\n'
fi

cat <<'EOF'
  After the review:
    • Clean → re-run with the bypass flag:
        CF_SKIP_REVIEW=1 git push <args>
    • Issues → address them, commit, re-run the gate.

  Intentional bypass (hotfix / docs / post-review):
        CF_SKIP_REVIEW=1 git push <args>
  ════════════════════════════════════════════════════════════

EOF

exit 1
